# ==============================================================
# TWILIO SMS CONFIGURATION (Para SMS Reminders)
# ==============================================================

# Your Twilio Account SID (find at https://console.twilio.com/)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Your Twilio Auth Token (KEEP SECRET! Never commit this!)
TWILIO_AUTH_TOKEN=your_auth_token_here_keep_secret

# Your Twilio Phone Number (format: +[country_code][number])
# Example: +351912345678 (Portugal), +33612345678 (France), +441234567890 (UK)
TWILIO_PHONE_NUMBER=+351912345678

# CRON Secret (for /api/reminders endpoint)
# Generate a strong random string: openssl rand -hex 32
CRON_SECRET=your_secure_cron_secret_here_at_least_32_chars

# ==============================================================
# NOTE: For production, use environment secrets storage:
# - Vercel: Project Settings > Environment Variables
# - Railway: Variables tab
# - Render: Environment > Add Secret
# ==============================================================
